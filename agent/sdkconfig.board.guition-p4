# Target
CONFIG_IDF_TARGET="esp32p4"

# Console (P4 has native USB Serial/JTAG)
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
# CONFIG_ESP_CONSOLE_UART_DEFAULT is not set

# PSRAM — 32 MB HEX-mode, start at 200 MHz; fall back to 80M if unstable
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_HEX=y
CONFIG_SPIRAM_SPEED_200M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y

# Ethernet — internal EMAC + IP101 PHY (50 MHz REF_CLK external input)
CONFIG_ETH_USE_ESP32_EMAC=y
CONFIG_ETH_PHY_INTERFACE_RMII=y
CONFIG_ETH_RMII_CLK_INPUT=y
CONFIG_ETH_RMII_CLK_IN_GPIO=50
CONFIG_ETH_USE_OPENETH=n

# WiFi/BT disabled (P4 has no internal radio; C6 deferred)
# CONFIG_ESP_WIFI_ENABLED is not set
# CONFIG_BT_ENABLED is not set

# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
